---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Publications from '../components/Publications.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import SessionReplay from '../components/SessionReplay.astro';
import Footer from '../components/Footer.astro';
---

<style>
  .colophon {
    width: min(100% - 2.5rem, var(--wide-width));
    margin-inline: auto;
    padding: var(--space-12) 0 var(--space-16);
  }
  .colophon-label {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-faint);
    margin-bottom: var(--space-4);
  }
</style>

<BaseLayout>
  <Header />
  <main id="main" tabindex="-1">
    <Hero />
    <Publications />
    <Experience />
    <Education />
    <Projects />
    <div class="colophon" data-reveal>
      <p class="colophon-label">// made with claude code</p>
      <SessionReplay />
    </div>
  </main>
  <Footer />
</BaseLayout>
