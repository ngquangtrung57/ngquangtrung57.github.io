---
/* The QuoteBox: a little "model" with three knobs (expert / layer / heat) that
   index a grid of verified famous AI quotes — every knob combination is its
   own quote. Twisting a knob shakes the box snow-globe style: the words
   tumble out and the new quote settles in. Static fallback below is the
   default knob position. */
---

<aside class="quotebox" data-quotebox aria-label="AI quote box">
  <header class="bar">
    <span class="title">$ ./quotebox --grid 6×5×6</span>
    <button class="shake" type="button" data-shake>↻ shake</button>
  </header>

  <p class="quote" data-quote aria-live="polite">
    <span class="tk">Attention</span> <span class="tk">Is</span>
    <span class="tk">All</span> <span class="tk">You</span>
    <span class="tk">Need</span>
  </p>

  <p class="attribution" data-attr>— Vaswani et al., 2017</p>
  <p class="cell" data-cell>// llms × 2017–20 × canon</p>

  <div class="knobs">
    <div class="knob">
      <label for="k-expert">expert · <output data-expert-out>E0</output></label>
      <input id="k-expert" data-expert type="range" min="0" max="5" step="1" value="0" />
    </div>
    <div class="knob">
      <label for="k-layer">layer · <output data-layer-out>L2</output></label>
      <input id="k-layer" data-layer type="range" min="0" max="4" step="1" value="2" />
    </div>
    <div class="knob">
      <label for="k-heat">heat · <output data-heat-out>canon</output></label>
      <input id="k-heat" data-heat type="range" min="0" max="5" step="1" value="0" />
    </div>
  </div>

  <p class="hint">
    three knobs, one real quote per combination — the <em>//</em> line decodes
    where you landed. shake the box for a random cell.
  </p>
</aside>

<script>
  import { mountQuoteBox } from '../scripts/quotebox';

  const root = document.querySelector<HTMLElement>('[data-quotebox]');
  if (root) mountQuoteBox(root);
</script>

<style>
  .quotebox {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-terminal);
    padding: var(--space-6);
    box-shadow: 0 0 40px var(--accent-dim);
  }

  .bar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px dashed var(--border);
  }

  .title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .shake {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    padding: 0.15rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition);
  }

  .shake:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .quote {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.9vw, 1.3rem);
    font-weight: 460;
    line-height: 1.75;
    letter-spacing: -0.005em;
    min-height: 6.2em; /* room for the longest quote, so swapping doesn't shift layout */
  }

  /* word spans; .tk elements are (re)built by the script */
  .quote :global(.tk) {
    display: inline-block;
    color: var(--text);
    will-change: transform;
  }

  /* phase 1: the old words tumble up and out of the box */
  .quote :global(.tk.lift) {
    transform: translate(var(--lx), var(--ly)) rotate(var(--lr));
    opacity: 0;
    transition:
      transform 260ms ease-in,
      opacity 240ms ease-in;
  }

  /* phase 2: the new words drop in and settle with a little overshoot */
  .quote :global(.tk.drop) {
    animation: tk-settle 640ms cubic-bezier(0.22, 0.8, 0.3, 1.04) both;
  }

  @keyframes tk-settle {
    0% {
      transform: translate(var(--sx), var(--sy)) rotate(var(--sr));
      opacity: 0;
    }
    55% {
      transform: translate(calc(var(--sx) * -0.2), calc(var(--sy) * -0.15))
        rotate(calc(var(--sr) * -0.35));
      opacity: 1;
    }
    100% {
      transform: none;
      opacity: 1;
    }
  }

  .attribution {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
  }

  .cell {
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
  }

  .knobs {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: var(--space-6);
    row-gap: var(--space-4);
  }

  .knob label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    margin-bottom: var(--space-2);
  }

  .knob output {
    color: var(--accent);
    font-weight: 500;
  }

  input[type='range'] {
    width: 100%;
    accent-color: var(--accent);
    cursor: ew-resize;
  }

  .hint {
    margin-top: var(--space-4);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--text-faint);
  }

  .hint em {
    color: var(--text-muted);
  }
</style>
