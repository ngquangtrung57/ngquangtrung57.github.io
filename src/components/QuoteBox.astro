---
/* The QuoteBox: a little "model" with three knobs (topic / era / heat) that
   index a grid of verified famous AI quotes — every knob combination is its
   own quote. The SVG network flickers and the tokens scatter-and-settle on
   every twist. Static fallback below is the default knob position. */

// tiny feed-forward net: 4-5-5-3 nodes, all adjacent layers connected
const LAYERS = [4, 5, 5, 3];
const XS = [16, 112, 208, 304];
const nodeY = (n: number, i: number) => 36 + (i - (n - 1) / 2) * 14;
const nodes = LAYERS.flatMap((n, l) =>
  Array.from({ length: n }, (_, i) => ({ x: XS[l]!, y: nodeY(n, i) }))
);
const edges: { x1: number; y1: number; x2: number; y2: number }[] = [];
for (let l = 0; l < LAYERS.length - 1; l++) {
  for (let a = 0; a < LAYERS[l]!; a++) {
    for (let b = 0; b < LAYERS[l + 1]!; b++) {
      edges.push({
        x1: XS[l]!,
        y1: nodeY(LAYERS[l]!, a),
        x2: XS[l + 1]!,
        y2: nodeY(LAYERS[l + 1]!, b),
      });
    }
  }
}
---

<aside class="quotebox" data-quotebox aria-label="AI quote box">
  <header class="bar">
    <span class="title">$ ./quotebox --grid topic×era×heat</span>
    <button class="shake" type="button" data-shake>↻ shake</button>
  </header>

  <svg
    class="net"
    data-net
    viewBox="0 0 320 72"
    role="img"
    aria-label="Decorative neural network"
  >
    {edges.map((e) => <line x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2} />)}
    {nodes.map((n) => <circle cx={n.x} cy={n.y} r="2.6" />)}
  </svg>

  <p class="quote" data-quote aria-live="polite">
    <span class="tk">Attention</span> <span class="tk">Is</span>
    <span class="tk">All</span> <span class="tk">You</span>
    <span class="tk">Need</span>
  </p>

  <p class="attribution" data-attr>— Vaswani et al., 2017</p>
  <p class="cell" data-cell>// llms × 2017–20 × canon</p>

  <div class="knobs">
    <div class="knob knob-wide">
      <label for="k-topic">topic · <output data-topic-out>llms</output></label>
      <input id="k-topic" data-topic type="range" min="0" max="5" step="1" value="0" />
      <div class="scale" aria-hidden="true">
        <span>llms</span>
        <span>alignment</span>
      </div>
    </div>
    <div class="knob">
      <label for="k-era">era · <output data-era-out>2017–20</output></label>
      <input id="k-era" data-era type="range" min="0" max="4" step="1" value="2" />
    </div>
    <div class="knob">
      <label for="k-heat">heat · <output data-heat-out>canon</output></label>
      <input id="k-heat" data-heat type="range" min="0" max="5" step="1" value="0" />
    </div>
  </div>

  <p class="hint">
    three knobs, one quote per combination — all real, all sourced. crank
    <em>heat</em> for the hot takes, or shake the whole box.
  </p>
</aside>

<script>
  import { mountQuoteBox } from '../scripts/quotebox';

  const root = document.querySelector<HTMLElement>('[data-quotebox]');
  if (root) mountQuoteBox(root);
</script>

<style>
  .quotebox {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-terminal);
    padding: var(--space-6);
    box-shadow: 0 0 40px var(--accent-dim);
  }

  .bar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px dashed var(--border);
  }

  .title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .shake {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    padding: 0.15rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition);
  }

  .shake:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .net {
    width: 100%;
    height: 64px;
    margin-bottom: var(--space-3);
  }

  .net line {
    stroke: var(--text-faint);
    stroke-width: 0.6;
    transition: opacity 450ms ease;
  }

  .net circle {
    fill: var(--accent);
    transition: opacity 450ms ease;
  }

  .quote {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.9vw, 1.3rem);
    font-weight: 460;
    line-height: 1.75;
    letter-spacing: -0.005em;
    min-height: 6.2em; /* room for the longest quote, so swapping doesn't shift layout */
  }

  /* token chips; .tk elements are (re)built by the script */
  .quote :global(.tk) {
    display: inline-block;
    padding: 0 0.18em;
    border-radius: var(--radius-sm);
    background: var(--accent-dim);
    color: var(--text);
    transform: translate(0, 0) rotate(0deg);
    transition:
      transform 340ms cubic-bezier(0.2, 0.9, 0.3, 1.15),
      opacity 240ms ease;
  }

  .quote :global(.tk.scatter) {
    transform: translate(var(--dx, 0), var(--dy, 0)) rotate(var(--rot, 0deg));
    opacity: 0.25;
    transition:
      transform 200ms ease-in,
      opacity 180ms ease-in;
  }

  .attribution {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
  }

  .cell {
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
  }

  .knobs {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-6);
    row-gap: var(--space-4);
  }

  .knob-wide {
    grid-column: 1 / -1;
  }

  .knob label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    margin-bottom: var(--space-2);
  }

  .knob output {
    color: var(--accent);
    font-weight: 500;
  }

  input[type='range'] {
    width: 100%;
    accent-color: var(--accent);
    cursor: ew-resize;
  }

  .scale {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-faint);
    margin-top: var(--space-1);
  }

  .hint {
    margin-top: var(--space-4);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--text-faint);
  }

  .hint em {
    color: var(--text-muted);
  }
</style>
