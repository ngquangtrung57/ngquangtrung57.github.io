---
import { profile } from '../data/profile';
import QuoteBox from './QuoteBox.astro';

const links = [
  { label: 'github', href: profile.links.github, external: true },
  { label: 'scholar', href: profile.links.scholar, external: true },
  { label: 'linkedin', href: profile.links.linkedin, external: true },
  { label: 'email', href: `mailto:${profile.email}`, external: false },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <h1>Nguyen Quang<br /><em>Trung</em></h1>
      <p class="role">
        Interested in <strong>multimodal LLMs</strong> —
        currently most excited about <strong>RL</strong> for reasoning and alignment.
      </p>

      <div class="bio">
        {profile.bio.map((paragraph) => <p set:html={paragraph} />)}
      </div>


      <ul class="links">
        {
          links.map((link) => (
            <li>
              <a
                class="link-chip"
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener' : undefined}
              >
                {link.label} <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="hero-term">
      <QuoteBox />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
  }

  /* the hero breathes wider than --content-width */
  .hero-inner {
    width: min(100% - 2.5rem, var(--wide-width));
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
    gap: var(--space-12);
  }

  h1 {
    font-size: clamp(2.9rem, 6.5vw, 4.5rem);
    font-weight: 480;
    line-height: 1.02;
    letter-spacing: -0.015em;
  }

  h1 em {
    font-style: italic;
    font-weight: 420;
    color: var(--accent);
  }

  .role {
    margin-top: var(--space-4);
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--text-muted);
    max-width: 30rem;
  }

  .role strong {
    color: var(--text);
    font-weight: 500;
  }

  .bio {
    margin-top: var(--space-6);
    max-width: 32rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .bio p {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .bio :global(a) {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
  }

  .bio :global(a:hover) {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .links {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .link-chip {
    display: inline-block;
    padding: 0.28rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-muted);
    transition:
      color var(--transition),
      border-color var(--transition);
  }

  .link-chip .arrow {
    color: var(--text-faint);
    transition: color var(--transition);
  }

  .link-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .link-chip:hover .arrow {
    color: var(--accent);
  }

  .hero-term {
    min-width: 0;
  }

  @media (max-width: 920px) {
    .hero {
      padding-top: var(--space-12);
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
