---
import Section from './Section.astro';
import { news } from '../data/news';
import { formatMonth, parseLinks } from '../data/format';

const items = news.slice(0, 6).map((item) => ({
  date: formatMonth(item.date),
  parts: parseLinks(item.text),
}));
---

<Section id="news" index="01" title="News">
  <ul class="news-list">
    {
      items.map((item) => (
        <li>
          <span class="meta date">{item.date}</span>
          <span class="text">
            {item.parts.map((part) =>
              part.type === 'link' ? (
                <a href={part.url} target="_blank" rel="noopener noreferrer">
                  {part.label}
                </a>
              ) : (
                part.value
              )
            )}
          </span>
        </li>
      ))
    }
  </ul>
</Section>

<style>
  .news-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  li {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }

  .date {
    white-space: nowrap;
    color: var(--text-faint);
  }

  .text {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    li {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
