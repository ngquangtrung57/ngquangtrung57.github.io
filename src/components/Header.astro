---
import { profile } from '../data/profile';

const sections = ['publications', 'experience', 'projects', 'contact'];
---

<header class="site-header">
  <div class="header-row">
    <a class="monogram" href="/" aria-label="Home">trung@ntu:~$</a>
    <nav class="anchors" aria-label="Sections">
      {
        sections.map((s, i) => (
          <>
            {i > 0 && <span class="sep" aria-hidden="true">·</span>}
            <a href={`/#${s}`}>{s}</a>
          </>
        ))
      }
    </nav>
    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle light/dark theme">
      <svg
        class="icon-sun"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4.4"></circle>
        <path d="M12 2.5v2.4M12 19.1v2.4M2.5 12h2.4M19.1 12h2.4M5.3 5.3l1.7 1.7M17 17l1.7 1.7M18.7 5.3 17 7M7 17l-1.7 1.7"></path>
      </svg>
      <svg
        class="icon-moon"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M20.5 14.6A8.6 8.6 0 0 1 9.4 3.5a8.6 8.6 0 1 0 11.1 11.1Z"></path>
      </svg>
    </button>
    <a
      class="gh"
      href={profile.links.github}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
        ></path>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--header-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-row {
    width: min(100% - 2.5rem, 64rem);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    height: 3.25rem;
  }

  .monogram {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    /* reserve space for the easter-egg ball so nothing shifts */
    padding-right: 1.4rem;
  }

  .monogram::after {
    content: '⚽';
    position: absolute;
    right: 0;
    top: 50%;
    font-size: 0.75rem;
    opacity: 0;
    transform: translate(-4px, -50%);
    transition: opacity var(--transition), transform var(--transition);
    pointer-events: none;
  }

  .monogram:hover {
    text-decoration: none;
    text-shadow: 0 0 14px var(--border-glow);
  }

  .monogram:hover::after {
    opacity: 1;
    transform: translate(0, -50%);
  }

  .anchors {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .anchors a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .anchors a:hover {
    color: var(--accent);
    text-decoration: none;
    text-shadow: 0 0 14px var(--border-glow);
  }

  .sep {
    color: var(--text-faint);
    user-select: none;
  }

  .gh {
    display: inline-flex;
    align-items: center;
    color: var(--text-muted);
  }

  .gh:hover {
    color: var(--accent);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition);
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* moon shown in dark mode, sun in light mode */
  .icon-sun {
    display: none;
  }

  :global(html[data-theme='light']) .icon-sun {
    display: block;
  }

  :global(html[data-theme='light']) .icon-moon {
    display: none;
  }

  @media (min-width: 720px) {
    .gh {
      display: none;
    }
  }

  @media (max-width: 719.98px) {
    .anchors {
      display: none;
    }

    .theme-toggle {
      margin-left: auto;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {}
    document
      .querySelector('meta[name="theme-color"]')
      ?.setAttribute('content', next === 'light' ? '#f6f1e6' : '#0b0e14');
  });
</script>
