---
const stages = [
  { id: 'input', label: 'input' },
  { id: 'tokenize', label: 'tokenize' },
  { id: 'attend', label: 'attend' },
  { id: 'logits', label: 'logits' },
  { id: 'decode', label: 'decode' },
];
---

<div class="fp" data-forward-pass role="group" aria-label="Interactive: trace a forward pass through a multimodal LLM">
  <div class="fp-bar">
    <span class="fp-title">trung-omni-7b</span>
    <span class="fp-sub">$ forward_pass --interactive</span>
  </div>

  <div data-stages-area>
    <div class="fp-pipe" data-pipe>
      {
        stages.map((s, i) => (
          <>
            {i > 0 && <span class="fp-link" aria-hidden="true" />}
            <button type="button" class="fp-stage" data-stage={s.id} aria-pressed="false">
              {s.label}
            </button>
          </>
        ))
      }
    </div>

    <div class="fp-view" aria-live="polite">
      <!-- 1 · input -->
      <div class="fp-panel" data-panel="input" hidden>
        <p class="fp-cap">a multimodal prompt arrives — text and audio together</p>
        <div class="modalities">
          <div class="modality">
            <span class="m-tag">text</span>
            <span class="m-text">“what's playing?”</span>
          </div>
          <div class="modality">
            <span class="m-tag">audio</span>
            <span class="m-wave" aria-hidden="true">
              <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
            </span>
          </div>
        </div>
      </div>

      <!-- 2 · tokenize -->
      <div class="fp-panel" data-panel="tokenize" hidden>
        <p class="fp-cap">the prompt becomes tokens; audio becomes frames</p>
        <div class="tok-row">
          <span class="tok"><span class="tok-t">▁what</span><span class="tok-id">1547</span></span>
          <span class="tok"><span class="tok-t">'s</span><span class="tok-id">594</span></span>
          <span class="tok"><span class="tok-t">▁playing</span><span class="tok-id">7203</span></span>
          <span class="tok"><span class="tok-t">?</span><span class="tok-id">30</span></span>
          <span class="tok audio"><span class="tok-t">⟨a₀…a₇₄⟩</span><span class="tok-id">audio×75</span></span>
        </div>
      </div>

      <!-- 3 · attend -->
      <div class="fp-panel" data-panel="attend" hidden>
        <p class="fp-cap">text tokens attend to audio frames — layer 17, head 4</p>
        <div class="attn" aria-hidden="true">
          {
            Array.from({ length: 36 }, (_, i) => {
              // deterministic pseudo-pattern, brighter on the diagonal band
              const r = Math.floor(i / 6);
              const c = i % 6;
              const v = Math.abs(((i * 37) % 23) / 23 - 0.5) * 0.5 + (Math.abs(r - c) <= 1 ? 0.45 : 0.05);
              return <i style={`--v:${Math.min(v, 0.95).toFixed(2)}`} />;
            })
          }
        </div>
      </div>

      <!-- 4 · logits -->
      <div class="fp-panel" data-panel="logits" hidden>
        <p class="fp-cap">one distribution over the next token</p>
        <div class="bars">
          <div class="bar"><span class="b-label">▁guitar</span><span class="b-track"><span class="b-fill" style="--w:46%"></span></span><span class="b-prob">0.46</span></div>
          <div class="bar"><span class="b-label">▁music</span><span class="b-track"><span class="b-fill" style="--w:27%"></span></span><span class="b-prob">0.27</span></div>
          <div class="bar"><span class="b-label">▁a</span><span class="b-track"><span class="b-fill" style="--w:14%"></span></span><span class="b-prob">0.14</span></div>
          <div class="bar"><span class="b-label">▁nothing</span><span class="b-track"><span class="b-fill" style="--w:08%"></span></span><span class="b-prob">0.08</span></div>
        </div>
        <button type="button" class="fp-play" data-play>▸ play: be the sampler</button>
      </div>

      <!-- 5 · decode -->
      <div class="fp-panel" data-panel="decode" hidden>
        <p class="fp-cap">sampled, token by token</p>
        <p class="decode-line"><span data-decode-line></span><span class="caret" aria-hidden="true"></span></p>
      </div>

      <!-- game overlay -->
      <div class="fp-game" data-game hidden></div>
    </div>
  </div>
</div>

<script>
  import { mountForwardPass } from '../scripts/forward-pass';

  const root = document.querySelector<HTMLElement>('[data-forward-pass]');
  if (root) mountForwardPass(root);
</script>

<style>
  .fp {
    background: var(--bg-terminal);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow:
      0 1px 0 rgba(233, 228, 216, 0.04) inset,
      0 24px 60px -20px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    font-family: var(--font-mono);
  }

  .fp-bar {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(233, 228, 216, 0.02);
  }

  .fp-title {
    font-size: 0.74rem;
    color: var(--text);
  }

  .fp-sub {
    font-size: 0.68rem;
    color: var(--text-faint);
  }

  /* --- pipeline rail --- */
  .fp-pipe {
    display: flex;
    align-items: center;
    padding: 0.9rem 1rem 0.6rem;
    gap: 0;
  }

  .fp-stage {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    cursor: pointer;
    transition:
      color var(--transition),
      border-color var(--transition),
      box-shadow var(--transition);
    white-space: nowrap;
  }

  .fp-stage.passed {
    color: var(--text-faint);
  }

  .fp-stage.active {
    color: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 14px var(--border-glow);
  }

  .fp-stage:hover {
    color: var(--accent);
  }

  .fp-link {
    flex: 1;
    height: 1px;
    min-width: 6px;
    background: var(--border);
    position: relative;
    overflow: visible;
  }

  /* travelling pulse on each connector */
  .fp-link::after {
    content: '';
    position: absolute;
    top: -1.5px;
    left: 0;
    width: 8px;
    height: 4px;
    border-radius: 2px;
    background: var(--accent);
    opacity: 0.7;
    animation: fp-pulse 1.6s linear infinite;
  }

  @keyframes fp-pulse {
    from {
      left: -8px;
    }
    to {
      left: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fp-link::after {
      animation: none;
      opacity: 0;
    }
  }

  /* --- detail view --- */
  .fp-view {
    height: 13.5rem;
    padding: 0.7rem 1rem 1rem;
    position: relative;
  }

  .fp-panel.active {
    animation: fp-in 280ms cubic-bezier(0.2, 0, 0.2, 1);
  }

  @keyframes fp-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fp-panel.active {
      animation: none;
    }
  }

  .fp-cap {
    font-size: 0.7rem;
    color: var(--text-faint);
    margin-bottom: var(--space-3);
  }

  /* input */
  .modalities {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .modality {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.7rem;
    background: var(--bg-inset);
  }

  .m-tag {
    font-size: 0.62rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    min-width: 3rem;
  }

  .m-text {
    font-size: 0.8rem;
    color: var(--text);
  }

  .m-wave {
    display: flex;
    align-items: center;
    gap: 3px;
    height: 22px;
  }

  .m-wave i {
    width: 3px;
    border-radius: 2px;
    background: var(--accent-2);
    height: 30%;
    animation: wave 1.1s ease-in-out infinite;
  }

  .m-wave i:nth-child(2) { animation-delay: 0.12s; }
  .m-wave i:nth-child(3) { animation-delay: 0.24s; }
  .m-wave i:nth-child(4) { animation-delay: 0.36s; }
  .m-wave i:nth-child(5) { animation-delay: 0.48s; }
  .m-wave i:nth-child(6) { animation-delay: 0.6s; }
  .m-wave i:nth-child(7) { animation-delay: 0.72s; }

  @keyframes wave {
    0%, 100% { height: 25%; }
    50% { height: 95%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .m-wave i {
      animation: none;
      height: 60%;
    }
  }

  /* tokenize */
  .tok-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tok {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.5rem;
    background: var(--bg-inset);
    opacity: 0;
  }

  .fp-panel.active .tok {
    animation: tok-in 240ms ease-out forwards;
  }

  .fp-panel.active .tok:nth-child(1) { animation-delay: 0.05s; }
  .fp-panel.active .tok:nth-child(2) { animation-delay: 0.15s; }
  .fp-panel.active .tok:nth-child(3) { animation-delay: 0.25s; }
  .fp-panel.active .tok:nth-child(4) { animation-delay: 0.35s; }
  .fp-panel.active .tok:nth-child(5) { animation-delay: 0.5s; }

  @keyframes tok-in {
    from {
      opacity: 0;
      transform: translateY(5px) scale(0.96);
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tok,
    .fp-panel.active .tok {
      animation: none;
      opacity: 1;
    }
  }

  .tok-t {
    font-size: 0.74rem;
    color: var(--text);
  }

  .tok.audio .tok-t {
    color: var(--accent-2);
  }

  .tok-id {
    font-size: 0.6rem;
    color: var(--text-faint);
  }

  /* attend */
  .attn {
    display: grid;
    grid-template-columns: repeat(6, 1.55rem);
    gap: 4px;
  }

  .attn i {
    height: 1.55rem;
    border-radius: 3px;
    background: var(--accent);
    opacity: calc(var(--v) * 0.9 + 0.04);
    transition: opacity 300ms ease, transform var(--transition);
  }

  .attn i:hover {
    transform: scale(1.12);
    opacity: 1;
  }

  /* logits */
  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .bar {
    display: grid;
    grid-template-columns: 5.2rem 1fr 2.4rem;
    align-items: center;
    gap: 0.6rem;
  }

  .b-label {
    font-size: 0.72rem;
    color: var(--text);
    text-align: right;
  }

  .b-track {
    height: 0.85rem;
    background: var(--bg-inset);
    border-radius: 3px;
    overflow: hidden;
  }

  .b-fill {
    display: block;
    height: 100%;
    width: 0;
    border-radius: 3px;
    background: linear-gradient(to right, rgba(245, 183, 85, 0.45), var(--accent));
  }

  .fp-panel.active .b-fill {
    animation: bar-grow 600ms cubic-bezier(0.2, 0, 0.2, 1) forwards;
  }

  @keyframes bar-grow {
    to {
      width: var(--w);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .b-fill,
    .fp-panel.active .b-fill {
      animation: none;
      width: var(--w);
    }
  }

  .b-prob {
    font-size: 0.66rem;
    color: var(--text-faint);
  }

  .fp-play {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    transition: box-shadow var(--transition);
  }

  .fp-play:hover {
    box-shadow: 0 0 16px var(--border-glow);
  }

  /* decode */
  .decode-line {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.6;
  }

  .caret {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    animation: blink 1.05s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation: none;
    }
  }

  /* --- game (elements created by forward-pass.ts) --- */
  .fp-game {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: 0.9rem 1rem 1.1rem;
    min-height: 16rem;
  }

  .fp-game :global(.g-meta) {
    font-size: 0.66rem;
    color: var(--text-faint);
  }

  .fp-game :global(.g-ctx) {
    font-size: 0.95rem;
    color: var(--text);
  }

  .fp-game :global(.g-options) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .fp-game :global(.g-token),
  .fp-game :global(.g-next),
  .fp-game :global(.g-back) {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    transition:
      color var(--transition),
      border-color var(--transition);
  }

  .fp-game :global(.g-token:hover:not(:disabled)),
  .fp-game :global(.g-next:hover),
  .fp-game :global(.g-back:hover) {
    color: var(--accent);
    border-color: var(--accent);
  }

  .fp-game :global(.g-token:disabled) {
    opacity: 0.45;
    cursor: default;
  }

  .fp-game :global(.g-next) {
    align-self: flex-start;
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .fp-game :global(.g-bars) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .fp-game :global(.g-bar-row) {
    display: grid;
    grid-template-columns: 4.6rem 1fr 2.2rem;
    align-items: center;
    gap: 0.6rem;
  }

  .fp-game :global(.g-bar-label) {
    font-size: 0.7rem;
    color: var(--text);
    text-align: right;
  }

  .fp-game :global(.g-bar-track) {
    height: 0.7rem;
    background: var(--bg-inset);
    border-radius: 3px;
    overflow: hidden;
  }

  .fp-game :global(.g-bar-fill) {
    height: 100%;
    background: linear-gradient(to right, rgba(245, 183, 85, 0.45), var(--accent));
    border-radius: 3px;
  }

  .fp-game :global(.g-bar-prob) {
    font-size: 0.64rem;
    color: var(--text-faint);
  }

  .fp-game :global(.g-result) {
    font-size: 0.74rem;
  }

  .fp-game :global(.g-result.ok) {
    color: var(--accent-2);
  }

  .fp-game :global(.g-result.miss) {
    color: #e0719a;
  }

  .fp-game :global(.g-score) {
    font-family: var(--font-display);
    font-size: 2.4rem;
    color: var(--accent);
    line-height: 1;
  }

  .fp-game :global(.g-verdict) {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
