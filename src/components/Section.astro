---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section id={id}>
  <div class="container">
    <p class="path" aria-hidden="true">~/{id}</p>
    <h2>{title}</h2>
    <slot />
  </div>
</section>

<style>
  section {
    padding-block: var(--space-12);
    scroll-margin-top: 4.5rem;
  }

  .path {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--accent);
    margin-bottom: var(--space-2);
  }

  .path::before {
    content: '$ cd ';
    color: var(--text-faint);
  }

  h2 {
    font-size: 1.9rem;
    margin-bottom: var(--space-8);
    position: relative;
    padding-bottom: var(--space-4);
  }

  h2::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, var(--border), transparent);
  }
</style>
