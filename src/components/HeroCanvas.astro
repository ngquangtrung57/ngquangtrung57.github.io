---
// Decorative attention-field panel. Pointer events are tracked on the panel
// itself; the canvas is purely a render target.
---

<div class="field-panel" data-attention-panel role="presentation">
  <canvas aria-hidden="true"></canvas>
</div>

<style>
  .field-panel {
    position: relative;
    height: 70vh;
    min-height: 24rem;
    /* CSS fallback glow behind the canvas */
    background: radial-gradient(ellipse at 50% 40%, #0d1530 0%, transparent 70%);
    /* melt edges into the page background — no hard box */
    -webkit-mask-image: radial-gradient(
      ellipse 75% 70% at 50% 50%,
      black 55%,
      transparent 98%
    );
    mask-image: radial-gradient(
      ellipse 75% 70% at 50% 50%,
      black 55%,
      transparent 98%
    );
    /* keep vertical scroll working on touch while still getting pointer events */
    touch-action: pan-y;
  }

  canvas {
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  @media (max-width: 860px) {
    .field-panel {
      height: 38vh;
      min-height: 14rem;
    }
  }
</style>

<script>
  import { mountAttentionField } from '../scripts/attention-field';

  const panel = document.querySelector<HTMLElement>('[data-attention-panel]');
  const canvas = panel?.querySelector('canvas');
  if (panel && canvas) mountAttentionField(panel, canvas);
</script>
