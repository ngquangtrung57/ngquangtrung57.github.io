---
const suggestions = ['help', 'cd publications', 'whoami', 'neofetch'];
---

<div class="term" data-terminal role="region" aria-label="Interactive terminal — type 'help' for commands">
  <div class="term-bar" aria-hidden="true">
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="term-title">trung@ntu: ~/research — zsh</span>
  </div>

  <div class="term-body" data-term-body>
    <div class="term-output" data-term-output aria-live="polite"></div>
    <div class="term-input-row">
      <span class="t-prompt" aria-hidden="true">trung@ntu:~$</span>
      <input
        class="term-input"
        data-term-input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        enterkeyhint="go"
        aria-label="Terminal command input — type 'help' for commands"
      />
    </div>
  </div>

  <div class="term-hints">
    {suggestions.map((s) => <button type="button" class="hint" data-term-cmd={s}>{s}</button>)}
  </div>
</div>

<script>
  import { mountTerminal } from '../scripts/terminal';

  const root = document.querySelector<HTMLElement>('[data-terminal]');
  if (root) mountTerminal(root);
</script>

<style>
  .term {
    background: var(--bg-terminal);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow:
      0 1px 0 rgba(233, 228, 216, 0.04) inset,
      0 24px 60px -20px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    position: relative;
  }

  /* subtle scanlines */
  .term::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0 2px,
      rgba(233, 228, 216, 0.012) 2px 3px
    );
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--border);
    background: rgba(233, 228, 216, 0.02);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2b3344;
  }

  .term-title {
    margin-inline: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
    user-select: none;
    /* visually re-center against the dots */
    transform: translateX(-1.4rem);
  }

  .term-body {
    height: 19rem;
    overflow-y: auto;
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    cursor: text;
  }

  .term-output {
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* line kinds (rendered by terminal.ts) */
  .term-output :global(.t-line) {
    color: var(--text-muted);
  }

  .term-output :global(.t-cmd) {
    color: var(--text);
  }

  .term-output :global(.t-ok) {
    color: var(--accent-2);
  }

  .term-output :global(.t-err) {
    color: #e0719a;
  }

  .term-output :global(.t-dim) {
    color: var(--text-faint);
  }

  .t-prompt,
  .term-output :global(.t-prompt) {
    color: var(--accent);
  }

  .term-input-row {
    display: flex;
    align-items: baseline;
    gap: 0.5ch;
    margin-top: 0.15rem;
  }

  .term-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font: inherit;
    caret-color: var(--accent);
    padding: 0;
  }

  .term-hints {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem 0.75rem;
    border-top: 1px solid var(--border);
  }

  .hint {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.14rem 0.6rem;
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition);
  }

  .hint:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
