---
import type { Project } from '../data/types';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const linkRow: { label: string; url: string }[] = [];
if (project.links.github) linkRow.push({ label: 'github', url: project.links.github });
if (project.links.post) linkRow.push({ label: 'post', url: project.links.post });

function fmtStars(n: number): string {
  return n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n);
}

const githubRepo = project.links.github
  ? project.links.github.replace('https://github.com/', '')
  : null;
---

<article class="card">
  <div class="head">
    <h3 class="name">{project.name}</h3>
    <div class="head-right">
      {project.stars != null && (
        <span
          class="stars"
          data-github-repo={githubRepo ?? undefined}
          data-stars-fallback={project.stars}
        >
          ★ {fmtStars(project.stars)}
        </span>
      )}
      <span class="chip">{project.role}</span>
    </div>
  </div>

  <p class="description">{project.description}</p>

  <div class="foot">
    <div class="tags">
      {project.tags.map((tag) => <span class="chip">{tag}</span>)}
    </div>
    {
      linkRow.length > 0 && (
        <div class="links">
          {linkRow.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              [{link.label}]
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color var(--transition);
  }

  .card:hover {
    border-color: var(--border-glow);
  }

  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .head-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .stars {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
  }

  .name {
    font-size: 1rem;
    font-weight: 600;
  }

  .description {
    font-size: 0.92rem;
    color: var(--text-muted);
    flex-grow: 1;
  }

  .foot {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .links {
    display: flex;
    gap: var(--space-3);
  }

  .links a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .links a:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>

<script>
  function fmtStars(n: number): string {
    return n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n)
  }

  document.querySelectorAll<HTMLElement>('[data-github-repo]').forEach(async (el) => {
    const repo = el.dataset.githubRepo
    if (!repo) return
    try {
      const res = await fetch(`https://api.github.com/repos/${repo}`, {
        headers: { Accept: 'application/vnd.github+json' },
      })
      if (!res.ok) return
      const data = await res.json()
      if (typeof data.stargazers_count === 'number') {
        el.textContent = `★ ${fmtStars(data.stargazers_count)}`
      }
    } catch {
      // keep static fallback
    }
  })
</script>
