---
import Section from './Section.astro';
import { skills } from '../data/skills';
---

<Section id="skills" index="05" title="Skills">
  <div class="groups">
    {
      skills.map((group) => (
        <div class="group">
          <span class="label">{group.label}</span>
          <div class="items">
            {group.items.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Section>

<style>
  .groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .group {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    min-width: 10rem;
    flex-shrink: 0;
  }

  .items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media (max-width: 480px) {
    .group {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
