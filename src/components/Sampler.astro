---
/* A tiny toy: one sentence about me, sampled live. Pick a prompt, drag the
   knobs (temperature / top_k / top_p), click a highlighted word to reroll
   just that one. The static markup below is the greedy (temp = 0) sentence
   for the default prompt, shown before JS loads. */
const promptIds = ['research', 'football', 'rl', 'phd', 'lol'];
---

<aside class="sampler" data-sampler aria-label="Sentence sampling toy">
  <header class="bar">
    <span class="title">$ ./sample --prompt <output data-prompt-out>research</output></span>
    <button class="reroll" type="button" data-reroll>↻ resample</button>
  </header>

  <div class="prompts" aria-label="Prompt">
    {
      promptIds.map((id, i) => (
        <button
          type="button"
          class="prompt-chip"
          data-prompt={id}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {id}
        </button>
      ))
    }
  </div>

  <p class="sentence" data-sentence aria-live="polite">
    I <button type="button" class="tok">train</button>
    <button type="button" class="tok">multimodal</button> models that
    <button type="button" class="tok">listen</button><button type="button" class="tok">.</button>
  </p>

  <p class="quip" data-quip>// greedy decoding. safe. a little boring.</p>

  <div class="knobs">
    <div class="knob knob-wide">
      <label for="k-temp">temperature · <output data-temp-out data-zone="warm">0.70</output></label>
      <input
        id="k-temp"
        data-temp
        type="range"
        min="0"
        max="2"
        step="0.05"
        value="0.7"
      />
      <div class="scale" aria-hidden="true">
        <span>0 · greedy</span>
        <span>2 · chaos</span>
      </div>
    </div>
    <div class="knob">
      <label for="k-topk">top_k · <output data-topk-out>7</output></label>
      <input id="k-topk" data-topk type="range" min="1" max="7" step="1" value="7" />
    </div>
    <div class="knob">
      <label for="k-topp">top_p · <output data-topp-out>1.00</output></label>
      <input
        id="k-topp"
        data-topp
        type="range"
        min="0.1"
        max="1"
        step="0.05"
        value="1"
      />
    </div>
  </div>

  <p class="joint meta">p(sentence) ≈ <span data-prob-out>—</span></p>

  <p class="hint">
    every highlighted word is sampled from real(ish) logits — switch prompts,
    turn the knobs, or click a word to resample it.
  </p>
</aside>

<script>
  import { mountSampler } from '../scripts/sampler';

  const root = document.querySelector<HTMLElement>('[data-sampler]');
  if (root) mountSampler(root);
</script>

<style>
  .sampler {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-terminal);
    padding: var(--space-6);
    box-shadow: 0 0 40px var(--accent-dim);
  }

  .bar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px dashed var(--border);
  }

  .title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .title output {
    color: var(--accent);
    font-weight: 500;
  }

  .reroll {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    padding: 0.15rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition);
  }

  .reroll:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .prompts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .prompt-chip {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    padding: 0.1rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition),
      background var(--transition);
  }

  .prompt-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .prompt-chip[aria-pressed='true'] {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .sentence {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    font-weight: 460;
    line-height: 1.8;
    letter-spacing: -0.005em;
    min-height: 5.2em; /* tallest prompt, so switching doesn't shift layout */
  }

  /* sampled-word chips; .tok elements are (re)built by the script */
  .sentence :global(.tok) {
    display: inline;
    padding: 0.04em 0.28em;
    margin-inline: 0.04em;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--accent-dim);
    font: inherit;
    color: var(--accent);
    cursor: pointer;
    transition: border-color var(--transition);
  }

  .sentence :global(.tok:hover) {
    border-color: var(--accent);
  }

  .sentence :global(.tok.flash) {
    animation: tok-flash 480ms ease-out;
  }

  @keyframes tok-flash {
    0% {
      background: var(--accent);
      color: var(--bg);
    }
    100% {
      background: var(--accent-dim);
      color: var(--accent);
    }
  }

  .quip {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
  }

  .knobs {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-6);
    row-gap: var(--space-4);
  }

  .knob-wide {
    grid-column: 1 / -1;
  }

  .knob label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    margin-bottom: var(--space-2);
  }

  .knob output {
    color: var(--text-muted);
    font-weight: 500;
  }

  .knob output[data-zone='cold'] {
    color: var(--accent-2);
  }

  .knob output[data-zone='warm'] {
    color: var(--accent);
  }

  .knob output[data-zone='hot'] {
    color: var(--accent-hot);
  }

  input[type='range'] {
    width: 100%;
    accent-color: var(--accent);
    cursor: ew-resize;
  }

  .scale {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-faint);
    margin-top: var(--space-1);
  }

  .joint {
    margin-top: var(--space-4);
    font-size: 0.72rem;
    color: var(--text-faint);
  }

  .joint span {
    color: var(--text-muted);
  }

  .hint {
    margin-top: var(--space-3);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--text-faint);
  }
</style>
