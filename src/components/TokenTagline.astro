---
import { profile } from '../data/profile';

const phrases = profile.taglinePhrases;
const firstPhrase = phrases[0] ?? '';
---

<div
  class="token-tagline"
  data-token-tagline
  data-phrases={JSON.stringify(phrases)}
>
  <p class="line" aria-live="off">
    <span class="prompt">I work on</span>
    <span data-tagline class="gen">{firstPhrase}</span><span
      class="caret"
      aria-hidden="true"></span>
  </p>
  <div data-chips class="chips" aria-hidden="true">
    <span class="cand"></span>
    <span class="cand"></span>
    <span class="cand"></span>
  </div>
</div>

<style>
  .token-tagline {
    font-family: var(--font-mono);
  }

  .line {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .prompt {
    color: var(--text-muted);
  }

  .gen {
    color: var(--text);
    font-weight: 600;
    transition: opacity 300ms ease;
  }

  .caret {
    display: inline-block;
    width: 1ch;
    height: 1.1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    animation: caret-blink 1.1s steps(2, jump-none) infinite;
  }

  @keyframes caret-blink {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
    /* reserve a row so chip text appearing later never shifts layout */
    min-height: 1.7rem;
    align-items: flex-start;
  }

  .cand {
    display: inline-block;
    min-width: 6ch;
    padding: 0.1rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-inset);
    font-size: 0.72rem;
    color: var(--text-faint);
    white-space: nowrap;
    transition:
      color var(--transition),
      border-color var(--transition),
      box-shadow var(--transition);
  }

  .cand:empty {
    border-color: transparent;
    background: transparent;
  }

  .cand.winner {
    color: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 10px var(--border-glow);
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation-play-state: paused;
    }
  }
</style>

<script>
  import { mountTokenTypewriter } from '../scripts/token-typewriter';

  const root = document.querySelector<HTMLElement>('[data-token-tagline]');
  if (root) {
    let phrases: string[] = [];
    try {
      const parsed: unknown = JSON.parse(root.dataset.phrases ?? '[]');
      if (Array.isArray(parsed)) {
        phrases = parsed.filter((p): p is string => typeof p === 'string');
      }
    } catch {
      /* fall back to the static phrase */
    }
    if (phrases.length > 0) mountTokenTypewriter(root, phrases);
  }
</script>
